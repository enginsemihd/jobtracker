{
  "name": "jobtrack",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.2",
  "scripts": {
    "db:push": "dotenv -e .env -- pnpm --filter @workspace/db push",
    "db:studio": "dotenv -e .env -- pnpm --filter @workspace/db studio",
    "dev:api": "dotenv -e .env -- pnpm --filter @workspace/api-server dev",
    "dev:web": "pnpm --filter @workspace/job-tracker dev",
    "dev": "dotenv -e .env -- concurrently -k -n api,web -c blue,green \"pnpm --filter @workspace/api-server dev\" \"pnpm --filter @workspace/job-tracker dev\"",
    "build": "pnpm --filter @workspace/job-tracker build",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "dotenv-cli": "^8.0.0"
  }
}
