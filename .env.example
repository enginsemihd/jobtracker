# --- Required ---
# Supabase: Project Settings → Database → Connection string → URI
# Use the DIRECT connection (port 5432) for `pnpm db:push`. Append ?sslmode=require
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[ref].supabase.co:5432/postgres?sslmode=require

# Port the API server listens on (the Vite dev proxy points here)
PORT=8080

# Claude API key for the AI tailoring feature
ANTHROPIC_API_KEY=sk-ant-...

# --- Job sources ---
JOOBLE_API_KEY=
# Adzuna is optional (no Turkey coverage). Leave blank to skip.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# --- Optional fetch-all tuning ---
# JOBS_MAX_PAGES=10
# JOBS_MAX_RESULTS_PER_SOURCE=500
# JOBS_PAGE_DELAY_MS=250
