# --- Required ---
# Supabase: Project Settings → Database → Connection string → URI
# Use the DIRECT connection (port 5432) for `pnpm db:push`. Append ?sslmode=require
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[ref].supabase.co:5432/postgres?sslmode=require

# Port the API server listens on (the Vite dev proxy points here)
PORT=8080

# Secret for signing JWT auth tokens (multi-user login). Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# Google Sign-In (optional). Same OAuth Client ID in both — GOOGLE_CLIENT_ID is
# used by the API to verify tokens, VITE_GOOGLE_CLIENT_ID by the browser to
# render the button. Leave both blank to hide Google sign-in entirely.
# Create one at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# Claude API key for the AI tailoring feature
ANTHROPIC_API_KEY=sk-ant-...

# --- Job sources ---
JOOBLE_API_KEY=
# Adzuna is optional (no Turkey coverage). Leave blank to skip.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Reed is optional (UK jobs only). Free key at reed.co.uk/developers. Leave blank to skip.
REED_API_KEY=
# Himalayas needs no key — always on when a remote search runs.
# Findwork is optional. Free token at findwork.dev. Leave blank to skip.
FINDWORK_API_KEY=
# USAJOBS is optional (US federal jobs, only fires for country="United States").
# Free key at developer.usajobs.gov — User-Agent must be the email you registered with.
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# --- Optional fetch-all tuning ---
# JOBS_MAX_PAGES=10
# JOBS_MAX_RESULTS_PER_SOURCE=500
# JOBS_PAGE_DELAY_MS=250
